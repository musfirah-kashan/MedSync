@{
    Layout = "_DoctorLayout";
}
@using MedSync.Models

<style>
    .chat-wrapper {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 0;
        height: calc(100vh - 130px);
        background: white;
        border-radius: 16px;
        border: 1px solid #d0eaec;
        overflow: hidden;
        min-height;
    }

    .chat-sidebar {
        border-right: 1px solid #d0eaec;
        display: flex;
        flex-direction: column;
        background: #fafefe;
    }

    .chat-sidebar-header {
        padding: 18px 20px;
        border-bottom: 1px solid #d0eaec;
        font-size: 0.95rem;
        font-weight: 700;
        color: #0d2b45;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .chat-sidebar-header i {
            color: #17bebb;
        }

    .chat-list {
        flex: 1;
        overflow-y: auto;
    }

    .chat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        cursor: pointer;
        text-decoration: none;
        border-bottom: 1px solid #f0fafa;
        transition: background 0.15s;
    }

        .chat-item:hover {
            background: #f0fafa;
        }

        .chat-item.active {
            background: rgba(23,190,187,0.08);
            border-right: 3px solid #17bebb;
        }

    .chat-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #0d2b45;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
        flex-shrink: 0;
        position: relative;
    }

    .unread-dot {
        position: absolute;
        top: 0;
        right: 0;
        width: 14px;
        height: 14px;
        background: #ef4444;
        border-radius: 50%;
        font-size: 0.6rem;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .chat-item-info .name {
        font-size: 0.88rem;
        font-weight: 600;
        color: #0d2b45;
    }

    .chat-item-info .sub {
        font-size: 0.75rem;
        color: #6b8a9a;
    }

    .chat-main {
        display: flex;
        flex-direction: column;
        height:100%;
        min-height:0;
    }

    .chat-topbar {
        padding: 14px 20px;
        border-bottom: 1px solid #d0eaec;
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
    }

        .chat-topbar .p-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: #0d2b45;
        }

    .chat-messages {
        flex: 1;
        min-height:0;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #f8fefe;
    }

    .msg-row {
        display: flex;
        align-items: flex-end;
        gap: 8px;
    }

        .msg-row.mine {
            flex-direction: row-reverse;
        }

    .msg-av {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: #0d2b45;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        flex-shrink: 0;
    }

        .msg-av.teal {
            background: #17bebb;
        }

    .msg-bubble {
        max-width: 65%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 0.88rem;
        line-height: 1.5;
        overflow-wrap: break-word;
        word-wrap: break-word;
        white-space: normal;
    }

    .msg-row.mine .msg-bubble {
        background: #0d2b45;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .msg-row.other .msg-bubble {
        background: white;
        color: #0d2b45;
        border: 1px solid #d0eaec;
        border-bottom-left-radius: 4px;
    }

    .msg-time {
        font-size: 0.68rem;
        color: #6b8a9a;
        margin-top: 4px;
    }

    .msg-row.mine .msg-time {
        text-align: right;
    }

    .msg-row.other .msg-time {
        text-align: left;
    }

    .chat-input-area {
        padding: 14px 20px;
        border-top: 1px solid #d0eaec;
        background: white;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .chat-input {
        flex: 1;
        padding: 11px 16px;
        border: 1.5px solid #d0eaec;
        border-radius: 25px;
        font-size: 0.88rem;
        outline: none;
        font-family: 'Poppins', sans-serif;
        transition: border-color 0.2s;
    }

        .chat-input:focus {
            border-color: #17bebb;
        }

    .btn-send {
        width: 42px;
        height: 42px;
        background: #17bebb;
        border: none;
        border-radius: 50%;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: background 0.2s;
        flex-shrink: 0;
    }

        .btn-send:hover {
            background: #0fa3a0;
        }

    .chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #6b8a9a;
        gap: 12px;
    }

        .chat-empty i {
            font-size: 3rem;
            opacity: 0.25;
        }
</style>

@{
    var me = ViewBag.Me as ApplicationUser;
    var patients = ViewBag.Patients as List<ApplicationUser>;
    var messages = ViewBag.Messages as List<ChatMessage>;
    var activePatientId = ViewBag.ActivePatientUserId as string;
    var unreadCounts = ViewBag.UnreadCounts as dynamic;

    Func<string, int> GetUnread = (uid) =>
    {
        if (unreadCounts == null) return 0;

        foreach (var u in unreadCounts)
        {
            if (u.SenderId == uid)
            {
                return (int)u.Count;
            }
        }

        return 0;
    };
}

<div class="chat-wrapper">

    <!-- Sidebar -->
    <div class="chat-sidebar">

        <div class="chat-sidebar-header">
            <i class="fa fa-users"></i> Patients
        </div>

        <div class="chat-list">

            @if (patients != null && patients.Any())
            {
                foreach (var p in patients)
                {
                    var isActive = activePatientId == p.Id;
                    var unread = GetUnread(p.Id);
                    var firstChar = (p.FullName ?? "P")[0].ToString().ToUpper();

                    <a href="/Chat/DoctorChat?patientUserId=@p.Id"
                       class="chat-item @(isActive ? "active" : "")">

                        <div class="chat-avatar">
                            @firstChar

                            @if (unread > 0)
                            {
                                <span class="unread-dot">@unread</span>
                            }
                        </div>

                        <div class="chat-item-info">
                            <div class="name">@p.FullName</div>
                            <div class="sub">@p.Email</div>
                        </div>

                    </a>
                }
            }
            else
            {
                <div style="padding:24px;text-align:center;color:#6b8a9a;font-size:0.85rem;">
                    No patients yet
                </div>
            }

        </div>
    </div>

    <!-- Main -->
    <div class="chat-main">

        @if (!string.IsNullOrEmpty(activePatientId))
        {
            <div class="chat-topbar">

                <div class="chat-avatar"
                     style="width:36px;height:36px;font-size:0.85rem;background:#17bebb;">
                    @((ViewBag.ActivePatientName as string)?[0].ToString().ToUpper())
                </div>

                <div>
                    <div class="p-name">@ViewBag.ActivePatientName</div>
                    <div style="font-size:0.76rem;color:#6b8a9a;">Patient</div>
                </div>

            </div>

            <div class="chat-messages" id="msgContainer">

                @if (messages != null && messages.Any())
                {
                    var lastId = 0;

                    foreach (var msg in messages)
                    {
                        var isMine = msg.SenderId == me?.Id;
                        lastId = msg.Id;

                        <div class="msg-row @(isMine ? "mine" : "other")">

                            <div class="msg-av @(isMine ? "" : "teal")">
                                @(isMine
                                                    ? (me?.FullName?[0].ToString().ToUpper() ?? "D")
                                                    : (ViewBag.ActivePatientName as string)?[0].ToString().ToUpper())
                </div>

                            <div>
                                <div class="msg-bubble">@msg.Message</div>
                                <div class="msg-time">
                                    @msg.SentAt.ToString("hh:mm tt")
                                </div>
                            </div>

                        </div>
                        }

                    <input type="hidden" id="lastMsgId" value="@lastId" />
                }
                else
                {
                    <input type="hidden" id="lastMsgId" value="0" />

                    <div style="text-align:center;color:#6b8a9a;margin-top:40px;font-size:0.88rem;">
                        No messages yet. Start the conversation! 👋
                    </div>
                }

            </div>

            <div class="chat-input-area">

                <form asp-controller="Chat"
                      asp-action="DoctorSend"
                      method="post"
                      id="sendForm"
                      style="display:flex;gap:10px;flex:1;align-items:center;">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="receiverId"
                           value="@activePatientId" />

                    <input type="text"
                           name="message"
                           id="msgInput"
                           class="chat-input"
                           placeholder="Type a message..."
                           autocomplete="off" />

                    <button type="submit" class="btn-send">
                        <i class="fa fa-paper-plane"></i>
                    </button>

                </form>

            </div>
        }
        else
        {
            <div class="chat-empty">
                <i class="fa fa-comments"></i>

                <p style="font-size:0.95rem;font-weight:600;color:#0d2b45;">
                    Select a patient to start chatting
                </p>
            </div>
        }

    </div>
</div>

@section Scripts {

    <script>

        (function () {

            var container = document.getElementById('msgContainer');
            var lastMsgInput = document.getElementById('lastMsgId');
            var otherUserId = '@activePatientId';

            if (!container || !otherUserId)
                return;

            function scrollBottom() {
                container.scrollTop = container.scrollHeight;
            }

            scrollBottom();

            function escHtml(str) {

                if (!str) return '';

                return str
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function poll() {

                var lastId = lastMsgInput
                    ? parseInt(lastMsgInput.value) || 0
                    : 0;

                fetch('/Chat/GetMessages?otherUserId='
                    + encodeURIComponent(otherUserId)
                    + '&lastId=' + lastId)

                    .then(function (r) {
                        return r.json();
                    })

                    .then(function (msgs) {

                        if (!msgs || msgs.length === 0)
                            return;

                        msgs.forEach(function (m) {

                            var row = document.createElement('div');

                            row.className =
                                'msg-row ' + (m.isMine ? 'mine' : 'other');

                            var avatarChar = m.isMine
                                ? '@(me?.FullName?[0].ToString().ToUpper() ?? "D")'
                                : '@((ViewBag.ActivePatientName as string)?[0].ToString().ToUpper())';

                            row.innerHTML =
                                '<div class="msg-av ' + (m.isMine ? '' : 'teal') + '">' +
                                    avatarChar +
                                '</div>' +
                                '<div>' +
                                    '<div class="msg-bubble">' +
                                        escHtml(m.message) +
                                    '</div>' +
                                    '<div class="msg-time">' +
                                        m.time +
                                    '</div>' +
                                '</div>';

                            container.appendChild(row);

                            if (lastMsgInput) {
                                lastMsgInput.value = m.id;
                            }
                        });

                        scrollBottom();
                    })

                    .catch(function (err) {
                        console.log(err);
                    });
            }

            setInterval(poll, 3000);

            var input = document.getElementById('msgInput');

            if (input) {

                input.addEventListener('keydown', function (e) {

                    if (e.key === 'Enter' && !e.shiftKey) {

                        e.preventDefault();

                        document.getElementById('sendForm').submit();
                    }
                });
            }

        })();

    </script>

}