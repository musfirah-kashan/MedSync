@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedSync — Patient Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --teal: #17bebb;
            --navy: #0d2b45;
            --bg: #f0fafa;
            --muted: #6b8a9a;
            --border: #d0eaec;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            min-height: 100vh;
        }

        .p-navbar {
            background: var(--navy);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.15);
        }

            .p-navbar .brand {
                font-size: 1.3rem;
                font-weight: 700;
                color: var(--teal);
                text-decoration: none;
            }

                .p-navbar .brand span {
                    color: white;
                }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .patient-name {
            color: rgba(255,255,255,0.85);
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .patient-avatar {
            width: 32px;
            height: 32px;
            background: var(--teal);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.82rem;
            color: white;
            font-weight: 600;
        }

        .btn-nav-logout {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            padding: 7px 18px;
            border-radius: 20px;
            font-size: 0.82rem;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
        }

            .btn-nav-logout:hover {
                background: rgba(255,255,255,0.2);
                color: white;
            }

        .p-wrapper {
            max-width: 1100px;
            margin: 32px auto;
            padding: 0 24px;
        }

        @@media (max-width: 640px) {
            .p-navbar

        {
            padding: 0 16px;
        }

        .p-wrapper {
            padding: 0 12px;
            margin: 16px auto;
        }

        .patient-name span {
            display: none;
        }

        }
    </style>
</head>
<body>

    @{
        var patientName = HttpContextAccessor.HttpContext?.Session?.GetString("PatientName") ?? "Patient";
        var firstLetter = patientName.Length > 0 ? patientName[0].ToString().ToUpper() : "P";
    }

    <nav class="p-navbar">
        <a href="/Patient/Dashboard" class="brand">MED<span>SYNC</span></a>
        <div class="nav-right">
            <div class="patient-name">
                <div class="patient-avatar">@firstLetter</div>
                <span>@patientName</span>
            </div>
            <a href="/Patient/Logout" class="btn-nav-logout">
                <i class="fa fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </nav>

    <div class="p-wrapper">
        @RenderBody()
    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>