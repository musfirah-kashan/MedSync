@{
    Layout = "_PatientLayout";
}
@using MedSync.Models

<style>
    .rx-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #d0eaec;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .rx-header {
        padding: 16px 24px;
        background: #f0fafa;
        border-bottom: 1px solid #d0eaec;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .rx-body {
        padding: 20px 24px;
    }

    .rx-section {
        margin-bottom: 16px;
    }

    .rx-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .rx-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px dashed #d0eaec;
        font-size: 0.87rem;
        color: #0d2b45;
    }

        .rx-item:last-child {
            border-bottom: none;
        }

    .btn-print {
        background: #0d2b45;
        color: white;
        padding: 7px 16px;
        border-radius: 8px;
        font-size: 0.78rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        border: none;
    }

    @@media print {
        .p-navbar, .btn-print, .btn-book-new {
            display: none !important;
        }

        .rx-card {
            break-inside: avoid;
        }
    }
</style>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
        <h2 style="font-size:1.4rem;font-weight:700;color:#0d2b45;margin-bottom:4px;">
            My Prescriptions
        </h2>
        <p style="font-size:0.85rem;color:#6b8a9a;">
            All prescriptions from your doctors
        </p>
    </div>
    <button class="btn-print" onclick="window.print()">
        <i class="fa fa-print"></i> Print All
    </button>
</div>

@{
    var prescriptions = ViewBag.Prescriptions as List<Prescription>;
}

@if (prescriptions != null && prescriptions.Any())
{
    foreach (var p in prescriptions)
    {
        <div class="rx-card" id="rx-@p.Id">
            <div class="rx-header">
                <div>
                    <div style="font-weight:700;font-size:0.95rem;color:#0d2b45;">
                        <i class="fa fa-file-medical" style="color:#17bebb;margin-right:6px;"></i>
                        Dr. @(p.Doctor?.FullName ?? "—")
                        <span style="font-size:0.78rem;color:#6b8a9a;font-weight:400;margin-left:8px;">
                            @(p.Doctor?.Specialization ?? "")
                        </span>
                    </div>
                    <div style="font-size:0.78rem;color:#6b8a9a;margin-top:2px;">
                        @p.CreatedAt.ToString("dddd, dd MMM yyyy")
                        @if (p.Appointment != null)
                        {
                            <span style="margin-left:8px;">
                                — Appointment: @p.Appointment.AppointmentDate.ToString("dd MMM yyyy hh:mm tt")
                            </span>
                        }
                    </div>
                </div>
                <button class="btn-print" onclick="printRx(@p.Id)">
                    <i class="fa fa-print"></i> Print
                </button>
            </div>

            <div class="rx-body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

                    <div>
                        @if (!string.IsNullOrEmpty(p.Diagnosis))
                        {
                            <div class="rx-section">
                                <div class="rx-section-title" style="color:#17bebb;">
                                    <i class="fa fa-stethoscope"></i> Diagnosis
                                </div>
                                <div style="font-size:0.9rem;font-weight:600;color:#0d2b45;
                                                        background:#f0fafa;padding:10px 14px;border-radius:8px;">
                                    @p.Diagnosis
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(p.Medicines))
                        {
                            <div class="rx-section">
                                <div class="rx-section-title" style="color:#10b981;">
                                    <i class="fa fa-pills"></i> Medicines
                                </div>
                                @foreach (var med in p.Medicines.Split('\n',
                                                    StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <div class="rx-item">
                                        <i class="fa fa-circle"
                                           style="color:#10b981;font-size:6px;flex-shrink:0;"></i>
                                        @med.Trim()
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div>
                        @if (!string.IsNullOrEmpty(p.Tests))
                        {
                            <div class="rx-section">
                                <div class="rx-section-title" style="color:#f59e0b;">
                                    <i class="fa fa-flask"></i> Tests / Investigations
                                </div>
                                @foreach (var test in p.Tests.Split('\n',
                                                    StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <div class="rx-item">
                                        <i class="fa fa-circle"
                                           style="color:#f59e0b;font-size:6px;flex-shrink:0;"></i>
                                        @test.Trim()
                                    </div>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(p.Notes))
                        {
                            <div class="rx-section">
                                <div class="rx-section-title" style="color:#6b8a9a;">
                                    <i class="fa fa-sticky-note"></i> Notes
                                </div>
                                <div style="font-size:0.85rem;color:#6b8a9a;font-style:italic;
                                                        background:#f0fafa;padding:10px 14px;border-radius:8px;">
                                    @p.Notes
                                </div>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    }
}
else
{
    <div style="background:white;border-radius:14px;border:1px solid #d0eaec;
                    padding:60px;text-align:center;color:#6b8a9a;">
        <i class="fa fa-file-medical" style="font-size:3rem;display:block;
               margin-bottom:16px;opacity:0.3;"></i>
        <p style="font-size:0.95rem;">No prescriptions yet.</p>
        <a href="/Patient/Appointment"
           style="display:inline-flex;align-items:center;gap:8px;background:#17bebb;
                      color:white;padding:10px 24px;border-radius:25px;font-weight:600;">
            <i class="fa fa-calendar-plus"></i> Book Appointment
        </a>
    </div>
}

@section Scripts {
    <script>
        function printRx(id) {

            const el = document.getElementById('rx-' + id);
            if (!el) return;

            const win = window.open('', '_blank');

            const styles = `
                <style>
                    body {
                        font-family: 'Poppins', sans-serif;
                        padding: 20px;
                        color: #0d2b45;
                    }

                    .rx-card {
                        border: 1px solid #d0eaec;
                        border-radius: 14px;
                    }

                    .rx-header {
                        background: #f0fafa;
                        padding: 15px;
                    }

                    .rx-body {
                        padding: 15px;
                    }

                    .rx-section-title {
                        font-weight: 700;
                        font-size: 12px;
                        margin-bottom: 6px;
                    }

                    .rx-item {
                        padding: 5px 0;
                        border-bottom: 1px dashed #ddd;
                    }

                    button {
                        display: none;
                    }
                </style>
            `;

            win.document.open();

            win.document.write(`
                <html>
                <head>
                    <title>Prescription</title>
                    ${styles}
                </head>
                <body>
                    <h2 style="color:#17bebb;">MedSync Prescription</h2>
                    <hr>
                    <div class="rx-card">
                        ${el.innerHTML}
                    </div>
                </body>
                </html>
            `);

            win.document.close();

            setTimeout(() => {
                win.focus();
                win.print();
                win.close();
            }, 300);
        }
    </script>
}